#
# Inspired by justinsteven's jax... a replacement for my kali VM
#

FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
	apt-utils \
	apt-transport-https \
	build-essential \
	ca-certificates \
	curl \
	dnsutils \
	gdb \
	git \
	inetutils-ping \
	iproute2 \
	jq \
	locales \
	lsb-release \
	netcat-openbsd \
	net-tools \
	nmap \
	man \
	procps \
	python3-pip \
	socat \
	sudo \
	tcpdump \
	tmux \
	unzip \
	vim \
	wget \
	zsh

%%CA_CERT_BLOCK%%
# install AWS CLI v2
RUN apt-get install -y libssl-dev libffi-dev \
    && cd /tmp \
    && curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip" \
    && unzip awscliv2.zip \
    && ./aws/install

# install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh

# install Node.js and Claude CLI and auggie
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && npm install -g @augmentcode/auggie

# install markdown renderer for dax-preview
RUN pip3 install --break-system-packages markdown pyyaml

# install dax-preview web server
RUN cat > /usr/local/bin/dax-preview << 'PYEOF'
#!/usr/bin/env python3
"""dax-preview — markdown, JSON, and YAML rendering HTTP server."""
import datetime
import http.server
import io
import json
import os
import html as html_module
import urllib.parse

try:
