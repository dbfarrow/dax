image: dax:latest

features:
  - workdir
  - dotfiles
  - claude
  - auggie
  - github
  - ssh
  - webpreview

workdir:
  container: work

claudedir:
  mount: ~/.claude

auggiedir:
  mount: ~/.augment

githubdir:
  mount: ~/.config/gh

awsdir:
  mount: ~/.aws

dotfiles:
  ro:
    - ~/.zshrc
    - ~/.vimrc
    - ~/.vim/
    - ~/.tmux.conf
  rw:
    - ~/.gitconfig
    - ~/.claude.json

backup:
  - ~/.claude/CLAUDE.md
  - ~/.claude/.settings.json
